{
  "info": {
    "name": "iDone NOC API",
    "description": "Network Operations Center API for iDone - Incident Management and Escalation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "your_api_key_here",
      "type": "string"
    },
    {
      "key": "incident_id",
      "value": "replace_with_incident_uuid",
      "type": "string"
    },
    {
      "key": "client_id",
      "value": "replace_with_client_uuid",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Inbound (Monitoring Tools)",
      "description": "Endpoints for external monitoring tools to create incidents",
      "item": [
        {
          "name": "Create Incident (Inbound)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/incidents/inbound",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "incidents",
                "inbound"
              ]
            },
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"details\": \"CRITICAL ALERT: Database CPU 100%\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin (Dashboard)",
      "description": "Admin endpoints for dashboard operations",
      "item": [
        {
          "name": "List Incidents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/admin/incidents",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "incidents"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "List Clients",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/admin/clients",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "clients"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "Create Manual Incident",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/admin/incidents",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "incidents"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"client_id\": \"{{client_id}}\",\n    \"details\": \"Manual trigger from Postman\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Acknowledge Incident",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/admin/incidents/{{incident_id}}/acknowledge",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "incidents",
                "{{incident_id}}",
                "acknowledge"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "Resolve Incident",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/admin/incidents/{{incident_id}}/resolve",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "incidents",
                "{{incident_id}}",
                "resolve"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        }
      ]
    },
    {
      "name": "Twilio Webhooks",
      "description": "Endpoints for Twilio callback webhooks (simulated)",
      "item": [
        {
          "name": "Twilio Callback - Acknowledge",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/twilio/callback?incident_id={{incident_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "twilio",
                "callback"
              ],
              "query": [
                {
                  "key": "incident_id",
                  "value": "{{incident_id}}"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "CallSid",
                  "value": "CA1234567890"
                },
                {
                  "key": "Digits",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Twilio Callback - Invalid Input",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/twilio/callback?incident_id={{incident_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "twilio",
                "callback"
              ],
              "query": [
                {
                  "key": "incident_id",
                  "value": "{{incident_id}}"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "CallSid",
                  "value": "CA1234567890"
                },
                {
                  "key": "Digits",
                  "value": "5"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Twilio Status Callback",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/twilio/status?incident_id={{incident_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "twilio",
                "status"
              ],
              "query": [
                {
                  "key": "incident_id",
                  "value": "{{incident_id}}"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "CallSid",
                  "value": "CA1234567890"
                },
                {
                  "key": "CallStatus",
                  "value": "completed"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin - Authentication",
      "description": "Authentication endpoints",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/admin/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "auth",
                "login"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin\"\n}"
            }
          },
          "response": []
        }
      ]
    }
  ]
}
